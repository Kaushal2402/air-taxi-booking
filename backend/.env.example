# Application
APP_NAME="Air Taxi Booking"
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (MySQL)
MYSQL_SERVER=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=air-taxi-booking

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Provider — Maps
MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=

# Provider — Payments
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Provider — Push (FCM)
PUSH_PROVIDER=fcm
FCM_SERVER_KEY=

# Provider — SMS
SMS_PROVIDER=generic_http
SMS_ENDPOINT=
SMS_API_KEY=
SMS_SENDER_ID=

# Provider — WhatsApp
WHATSAPP_PROVIDER=generic_cloud_api
WHATSAPP_ENDPOINT=
WHATSAPP_TOKEN=
WHATSAPP_FROM=

# Provider — Email (SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# Provider — Storage
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
